[Unit]
Description=Christine Remote Audio Sink
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/ChristineAI/christine-server
EnvironmentFile=-/root/ChristineAI/christine-server/remote_audio_sink.env
ExecStart=/usr/bin/python3 -u /root/ChristineAI/christine-server/remote_audio_sink.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
