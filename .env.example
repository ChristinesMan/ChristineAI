# ChristineAI environment configuration
# Copy this file to .env and fill in your real values.

# Core service hostnames
CHRISTINE_WERNICKE_SERVER=your-wernicke-server.lan
CHRISTINE_BROCA_SERVER=your-broca-server.lan
CHRISTINE_NEOCORTEX_SERVER=your-neocortex-server.lan

# Character configuration
CHRISTINE_USER_NAME=Phantom
CHRISTINE_CHAR_NAME=Christine

# Wernicke configuration
CHRISTINE_WERNICKE_PV_KEY=
CHRISTINE_WERNICKE_VAD=webrtcvad

# LLM configuration
CHRISTINE_ENABLED_LLMS=openrouter
CHRISTINE_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
CHRISTINE_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
CHRISTINE_OPENROUTER_SITE_URL=
CHRISTINE_OPENROUTER_SITE_NAME=ChristineAI

# STT configuration (comma-separated for failover order)
CHRISTINE_ENABLED_STTS=whisper,openrouter
CHRISTINE_OPENROUTER_STT_URL=https://openrouter.ai/api/v1/audio/transcriptions
CHRISTINE_OPENROUTER_STT_MODEL=mistralai/voxtral-mini-transcribe
CHRISTINE_OPENROUTER_STT_LANGUAGE=en
CHRISTINE_OPENROUTER_STT_TIMEOUT_SECONDS=60

# Optional API keys
# CHRISTINE_CHUB_API_KEY=your-chub-api-key
# CHRISTINE_OPENAI_API_KEY=sk-proj-your-openai-api-key
# CHRISTINE_GEMINI_API_KEY=your-gemini-api-key

# Optional service toggles
# CHRISTINE_ENABLED_TTSS=broca_server
# CHRISTINE_AUDIO_OUTPUT_MODE=local
# CHRISTINE_BROCA_TTS_CONCURRENCY=2
